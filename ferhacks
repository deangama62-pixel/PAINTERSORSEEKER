    CurrentOption = {"Head"},
    Callback = function(opt) AimbotSettings.TargetPart = opt[1] end
})

AimbotTab:CreateToggle({Name = "Hold RMB to Aim", CurrentValue = false, Callback = function(v) AimbotSettings.HoldToAim = v end})

-- Core Loops
table.insert(Connections, RunService.RenderStepped:Connect(UpdateESP))
table.insert(Connections, RunService.RenderStepped:Connect(AimbotLoop))
table.insert(Connections, RunService.RenderStepped:Connect(UpdateFOVPosition))  -- Keeps circle centered

local function Cleanup()
    for _, c in ipairs(Connections) do pcall(function() c:Disconnect() end) end
    for _, data in pairs(ESP) do 
        for _, obj in pairs(data) do pcall(function() obj:Remove() end) end 
    end
    pcall(function() FOVCircle:Remove() end)
    if ESPFolder then ESPFolder:Destroy() end
end

SettingsTab:CreateButton({Name = "Destroy Script", Callback = Cleanup})

Rayfield:Notify({
    Title = "ferHacks Paint Or Seek",
    Content = "Mobile ESP + Aimbot + Role Colors (Static Center FOV) Loaded",
    Duration = 6
})

